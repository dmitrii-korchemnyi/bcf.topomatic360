{
  "$schema": "node_modules/albatros/schema.json",
  "name": "ru.dkorchemnyi.topomatic360.bcf",
  "displayName": "BCF Manager for Topomatic 360",
  "description": "BCF manager for Topomatic 360 with BIMcollab-like workflow, separate manager/editor windows and import/export of BCF 2.0, 2.1, 3.0.",
  "version": "0.2.0",
  "main": "src/index.ts",
  "sdk": "^1.3.0",
  "apx": true,
  "scripts": {
    "serve": "albatros-cli serve",
    "build": "albatros-cli build",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "keywords": ["category::coordination", "bcf", "issues", "topomatic360"],
  "author": { "name": "Dmitrii Korchemnyi" },
  "license": "MIT",
  "icon": { "name": "logo.svg" },
  "devDependencies": {
    "albatros": "^1.3.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "xmlbuilder2": "^3.1.1"
  },
  "albatros": {
    "actions": {
      "bcf_manager": { "label": "BCF Manager", "cmd": "bcf:open-manager", "icon": "dashboard" },
      "bcf_create": { "label": "Создать замечание", "cmd": "bcf:create-topic", "icon": "add" },
      "bcf_import": { "label": "Импорт BCF", "cmd": "bcf:import", "icon": "folder_open" },
      "bcf_export": { "label": "Экспорт BCF", "cmd": "bcf:export", "icon": "save" },
      "bcf_edit": { "label": "Редактировать замечание", "cmd": "bcf:edit-selected-topic", "icon": "edit" },
      "bcf_focus": { "label": "Перейти к виду", "cmd": "bcf:focus-selected-topic", "icon": "visibility" },
      "bcf_add_comment": { "label": "Добавить комментарий", "cmd": "bcf:add-comment-selected-topic", "icon": "comment" },
      "bcf_resolve": { "label": "Устранить", "cmd": "bcf:set-status-resolved", "icon": "done" },
      "bcf_close": { "label": "Закрыть", "cmd": "bcf:set-status-closed", "icon": "task_alt" },
      "bcf_reopen": { "label": "Переоткрыть", "cmd": "bcf:set-status-reopened", "icon": "restart_alt" },
      "bcf_delete": { "label": "Удалить замечание", "cmd": "bcf:delete-selected-topic", "icon": "delete" },
      "bcf_about": { "label": "О плагине", "cmd": "bcf:about", "icon": "info" }
    },
    "menu": [
      {
        "label": "BCF",
        "submenu": [
          { "action": "bcf_manager" },
          { "action": "bcf_create" },
          { "tag": "s" },
          { "action": "bcf_import" },
          { "action": "bcf_export" },
          { "tag": "s" },
          { "action": "bcf_about" }
        ]
      }
    ],
    "pages": [
      {
        "tag": "bcf_page",
        "label": "BCF",
        "groups": [
          {
            "tag": "bcf_main",
            "label": "Менеджер",
            "items": [
              { "tag": "b", "action": "bcf_manager" },
              { "tag": "b", "action": "bcf_create" },
              { "tag": "s" },
              { "tag": "b", "action": "bcf_import" },
              { "tag": "b", "action": "bcf_export" }
            ]
          },
          {
            "tag": "bcf_status",
            "label": "Статусы",
            "items": [
              { "tag": "b", "action": "bcf_resolve" },
              { "tag": "b", "action": "bcf_close" },
              { "tag": "b", "action": "bcf_reopen" }
            ]
          }
        ]
      }
    ],
    "viewsContainers": {
      "bcf_container": { "label": "BCF", "icon": "comment", "container": "left" }
    },
    "views": {
      "bcf_topics": { "label": "Замечания", "type": "treeview", "cmd": "bcf:build-tree", "container": "bcf_container" }
    },
    "context": {
      "bcf-topic": [
        { "action": "bcf_focus" },
        { "action": "bcf_edit" },
        { "action": "bcf_add_comment" },
        { "tag": "s" },
        { "action": "bcf_resolve" },
        { "action": "bcf_close" },
        { "action": "bcf_reopen" },
        { "tag": "s" },
        { "action": "bcf_delete" }
      ],
      "bcf-viewpoint": [
        { "action": "bcf_focus" }
      ],
      "bcf-comment": [
        { "action": "bcf_edit" }
      ]
    },
    "statusbar": {
      "bcf_status": { "alignment": "left", "name": "BCF Manager", "cmd": "bcf:open-manager" }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dmitrii-korchemnyi/dkorchemnyi.topomatic360.bcf.git"
  },
  "homepage": "https://dmitrii-korchemnyi.github.io/dkorchemnyi.topomatic360.bcf/"
}
